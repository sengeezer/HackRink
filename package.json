{
  "name": "hackrink",
  "version": "1.0.0",
  "description": "Node.js playground workspace with JavaScript library samples.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"No tests configured\"",
    "sample:axios": "node samples/axios-example.js",
    "sample:babel": "npx babel samples/babel-source.js --out-file samples/babel-output.js --presets latest && node samples/babel-output.js",
    "sample:bignumber": "node samples/bignumber-example.js",
    "sample:coffee": "npx coffee samples/coffeescript-example.coffee",
    "sample:fetch": "node samples/node-fetch-example.js",
    "sample:lodash": "node samples/lodash-example.js",
    "sample:request": "node samples/request-example.js",
    "sample:ts": "npx tsc samples/typescript-example.ts --outDir samples/dist --target ES2019 --module commonjs --strict && node samples/dist/typescript-example.js",
    "sample:underscore": "node samples/underscore-example.js",
    "sample:combo": "node samples/combined-example.js"
  },
  "keywords": [],
  "author": "Fabio M. Albertin <fabio@albertin.co.uk> (http://ifab.io/)",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": "20.15.1"
  },
  "volta": {
    "node": "20.15.1",
    "npm": "10.7.0"
  },
  "dependencies": {
    "axios": "1.4.0",
    "babel-cli": "6.26.0",
    "babel-preset-latest": "6.24.1",
    "bignumber.js": "9.1.1",
    "coffeescript": "2.7.0",
    "jquery": "3.7.0",
    "lodash": "4.17.21",
    "node-fetch": "2.6.11",
    "request": "2.88.2",
    "typescript": "5.1.3",
    "underscore": "1.13.6"
  }
}
